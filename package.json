    "@typescript/native-preview": "7.0.0-dev.20260620.1",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "prettier": "3.8.4",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-tailwindcss": "0.8.0",
    "react-email": "6.6.3",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3"
