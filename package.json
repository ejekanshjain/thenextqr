{
  "name": "thenextqr",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "email:dev": "email dev --dir src/emails",
    "email:test": "bun ./src/scripts/test-mail.ts",
    "workflow:inspect": "workflow inspect runs --web",
    "build": "bun --bun next build",
    "build:docker": "docker build -t my-app .",
    "analyze": "ANALYZE=true bun --bun next build --webpack",
    "start": "bun --bun next start",
    "lint": "eslint",
    "type-check": "tsgo --incremental false",
    "format": "prettier --write \"./src/**/*.{js,cjs,mjs,jsx,ts,tsx}\"",
    "db:push": "drizzle-kit push",
    "db:seed": "bun ./src/scripts/seed.ts",
    "db:reset": "bun ./src/scripts/reset-db.ts",
    "db:studio": "drizzle-kit studio",
    "gen:auth": "bunx @better-auth/cli generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1073.0",
    "@aws-sdk/s3-request-presigner": "3.1073.0",
    "@ejekanshjain/simple-email-validator": "1.0.4",
    "@hookform/resolvers": "5.4.0",
    "@next/third-parties": "16.2.9",
    "@paralleldrive/cuid2": "3.3.0",
    "@react-email/render": "2.0.9",
    "@t3-oss/env-nextjs": "0.13.11",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-table": "8.21.3",
    "better-auth": "1.6.20",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.21.0",
    "next": "16.2.9",
    "next-safe-action": "8.5.5",
    "next-themes": "0.4.6",
    "nextjs-toploader": "3.9.17",
    "nodemailer": "9.0.1",
    "nuqs": "2.8.9",
    "postgres": "3.4.9",
    "radix-ui": "1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.80.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
