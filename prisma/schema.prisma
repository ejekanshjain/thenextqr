generator client {
    provider      = "prisma-client-js"
    binaryTargets = ["native", "linux-arm64-openssl-1.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Account {
    id                String  @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String? @db.Text
    access_token      String? @db.Text
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String? @db.Text
    session_state     String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now()) @db.Timestamptz()
    updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz()

    @@unique([provider, providerAccountId])
    @@map("Accounts")
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime @db.Timestamptz()

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now()) @db.Timestamptz()
    updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz()

    @@map("Sessions")
}

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime? @db.Timestamptz()
    image         String?

    stripeCustomerId     String?  @unique
    stripeSubscriptionId String?  @unique
    stripePriceId        String?
    currentPeriodEnd     DateTime @default(dbgenerated("get_trial_period_end()")) @db.Timestamptz()

    createdAt DateTime @default(now()) @db.Timestamptz()
    updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz()

    accounts       Account[]
    sessions       Session[]
    createdQRCodes QRCode[]  @relation("createdQRCodes")
    updatedQRCodes QRCode[]  @relation("updatedQRCodes")

    @@map("Users")
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime @db.Timestamptz()

    @@unique([identifier, token])
    @@map("VerificationTokens")
}

model Resource {
    id               String  @id @default(cuid())
    originalFilename String
    newFilename      String  @unique
    url              String  @unique
    cdnUrl           String? @unique
    qrCodeId         String? @unique

    createdAt DateTime @default(now()) @db.Timestamptz()
    updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz()

    qrCode QRCode? @relation("qrCodeLogo", fields: [qrCodeId], references: [id], onDelete: Cascade)

    @@map("Resources")
}

enum QRCodeType {
    website
    email
    sms
    phone
    // contact
    // pdf
}

model QRCode {
    id         String     @id @default(cuid())
    dynamic    Boolean
    name       String
    slug       String?    @unique
    type       QRCodeType @default(website)
    expires    DateTime?  @db.Timestamptz()
    totalScans Int        @default(0)

    website     String?
    phoneNumber String?
    message     String?
    email       String?
    subject     String?

    logo     Resource?       @relation("qrCodeLogo")
    scanLogs QRCodeScanLog[]

    createdAt   DateTime @default(now()) @db.Timestamptz()
    updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz()
    createdById String
    createdBy   User     @relation("createdQRCodes", fields: [createdById], references: [id], onDelete: Cascade)
    updatedById String
    updatedBy   User     @relation("updatedQRCodes", fields: [updatedById], references: [id], onDelete: Cascade)

    @@index([createdById])
    @@map("QRCodes")
}

model QRCodeScanLog {
    id             String  @id @default(cuid())
    qrCodeId       String
    ipAdress       String
    userAgent      String
    browserName    String?
    browserVersion String?
    osName         String?
    osVersion      String?
    deviceVendor   String?
    deviceModel    String?
    deviceType     String?

    qrCode QRCode @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now()) @db.Timestamptz()

    @@map("QRCodeScanLogs")
}

model ContactUs {
    id        String  @id @default(cuid())
    name      String
    email     String
    subject   String
    message   String
    ipAdress  String?
    userAgent String?

    createdAt DateTime @default(now()) @db.Timestamptz()
    updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz()

    @@map("ContactUs")
}
